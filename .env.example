# Copy to a local .env or agent-host environment. Do not commit real secrets.

OPENAI_API_KEY=replace_me
OPENAI_ECONOMY_MODEL=gpt-5.4-mini
OPENAI_STRONG_MODEL=gpt-5.4
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_PRICING_FILE=openai-pricing.example.json

CREATIVITY_LAYER_PROVIDER_MODE=live_openai
CREATIVITY_LAYER_EFFORT=quick
CREATIVITY_LAYER_PRIVACY=research
CREATIVITY_LAYER_BUDGET_USD=0.25
CREATIVITY_LAYER_SEARCH_MODE=off
CREATIVITY_LAYER_SEARCH_PROVIDER=auto
CREATIVITY_LAYER_SEARCH_STRICT=false
CREATIVITY_LAYER_LIVE_SEARCH_APPROVED=0

EXA_API_KEY=replace_me
BRAVE_SEARCH_API_KEY=replace_me
OPENAI_WEB_SEARCH_MODEL=gpt-5.4-mini
