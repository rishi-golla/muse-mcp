# Copy to a local .env or agent-host environment. Do not commit real secrets.

OPENAI_API_KEY=replace_me
OPENAI_ECONOMY_MODEL=gpt-5.4-mini
OPENAI_STRONG_MODEL=gpt-5.4
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional: Muse includes packaged default pricing for the example models.
OPENAI_PRICING_FILE=

MUSE_PROVIDER_MODE=live_openai
MUSE_EFFORT=quick
MUSE_PRIVACY=research
MUSE_BUDGET_USD=0.25
MUSE_SEARCH_MODE=off
MUSE_SEARCH_PROVIDER=auto
MUSE_SEARCH_STRICT=false
MUSE_LIVE_SEARCH_APPROVED=0

EXA_API_KEY=replace_me
BRAVE_SEARCH_API_KEY=replace_me
OPENAI_WEB_SEARCH_MODEL=gpt-5.4-mini
